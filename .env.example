# Copy this file to `.env` and fill in values before running.
APP_ENV=development
CLIENT=tenacious
LOG_LEVEL=INFO
ALLOW_REAL_PROSPECT_CONTACT=false

# Email providers
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_WEBHOOK_SECRET=
MAILERSEND_API_KEY=
MAILERSEND_FROM_EMAIL=

# SMS provider
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=
AFRICASTALKING_WEBHOOK_SECRET=

# Observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# CRM
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_PORTAL_ID=
HUBSPOT_WEBHOOK_SECRET=

# Calendar
CALCOM_API_KEY=
CALCOM_WEBHOOK_SECRET=
CALCOM_EVENT_TYPE_ID=

# Runtime
WEBHOOK_BASE_URL=
PLAYWRIGHT_BROWSERS_PATH=0
