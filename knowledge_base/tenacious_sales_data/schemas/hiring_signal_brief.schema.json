{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tenacious-training.dev/schemas/hiring_signal_brief.schema.json",
  "title": "Hiring Signal Brief",
  "description": "Structured enrichment artifact produced before outreach composition.",
  "type": "object",
  "required": [
    "prospect_domain",
    "prospect_name",
    "generated_at",
    "primary_segment_match",
    "segment_confidence",
    "crunchbase_firmographics",
    "ai_maturity",
    "hiring_velocity",
    "buying_window_signals",
    "data_sources_checked"
  ],
  "properties": {
    "prospect_domain": {
      "type": "string",
      "description": "Canonical company domain, e.g. acme.com."
    },
    "prospect_name": {
      "type": "string",
      "description": "Company name from Crunchbase."
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "UTC timestamp when this brief was generated."
    },
    "primary_segment_match": {
      "type": "string",
      "enum": [
        "segment_1_series_a_b",
        "segment_2_mid_market_restructure",
        "segment_3_leadership_transition",
        "segment_4_specialized_capability",
        "abstain"
      ]
    },
    "segment_confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "crunchbase_firmographics": {
      "type": "object",
      "required": ["industry_tags", "employee_band", "hq", "signal_confidence"],
      "properties": {
        "industry_tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "employee_band": {
          "type": "string"
        },
        "hq": {
          "type": "string"
        },
        "last_funding_stage": {
          "type": "string",
          "enum": ["seed", "series_a", "series_b", "series_c", "series_d_plus", "debt", "other", "unknown"]
        },
        "total_funding_usd": {
          "type": "integer",
          "minimum": 0
        },
        "source_url": {
          "type": "string",
          "format": "uri"
        },
        "signal_confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        }
      }
    },
    "ai_maturity": {
      "type": "object",
      "required": ["score", "confidence", "justifications"],
      "properties": {
        "score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 3
        },
        "confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "justifications": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["signal", "status", "weight", "confidence"],
            "properties": {
              "signal": {
                "type": "string",
                "enum": [
                  "ai_adjacent_open_roles",
                  "named_ai_ml_leadership",
                  "github_org_activity",
                  "executive_commentary",
                  "modern_data_ml_stack",
                  "strategic_communications"
                ]
              },
              "status": { "type": "string" },
              "weight": {
                "type": "string",
                "enum": ["high", "medium", "low"]
              },
              "confidence": {
                "type": "string",
                "enum": ["high", "medium", "low"]
              },
              "source_url": {
                "type": "string",
                "format": "uri"
              }
            }
          }
        }
      }
    },
    "hiring_velocity": {
      "type": "object",
      "required": ["open_roles_today", "open_roles_60_days_ago", "velocity_label", "signal_confidence"],
      "properties": {
        "open_roles_today": {
          "type": "integer",
          "minimum": 0
        },
        "open_roles_60_days_ago": {
          "type": "integer",
          "minimum": 0
        },
        "velocity_label": {
          "type": "string",
          "enum": ["tripled_or_more", "doubled", "increased_modestly", "flat", "declined", "insufficient_signal"]
        },
        "signal_confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "sources": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["builtin", "wellfound", "linkedin_public", "company_careers_page"]
          }
        }
      }
    },
    "buying_window_signals": {
      "type": "object",
      "properties": {
        "funding_event": {
          "type": "object",
          "properties": {
            "detected": { "type": "boolean" },
            "stage": {
              "type": "string",
              "enum": ["seed", "series_a", "series_b", "series_c", "series_d_plus", "debt", "other", "none"]
            },
            "amount_usd": { "type": "integer" },
            "closed_at": { "type": "string", "format": "date" },
            "source_url": { "type": "string", "format": "uri" },
            "signal_confidence": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 1.0
            }
          }
        },
        "layoff_event": {
          "type": "object",
          "properties": {
            "detected": { "type": "boolean" },
            "date": { "type": "string", "format": "date" },
            "headcount_reduction": { "type": "integer" },
            "percentage_cut": { "type": "number" },
            "source_url": { "type": "string", "format": "uri" },
            "signal_confidence": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 1.0
            }
          }
        },
        "leadership_change": {
          "type": "object",
          "properties": {
            "detected": { "type": "boolean" },
            "role": {
              "type": "string",
              "enum": ["cto", "vp_engineering", "cio", "chief_data_officer", "head_of_ai", "other", "none"]
            },
            "new_leader_name": { "type": "string" },
            "started_at": { "type": "string", "format": "date" },
            "source_url": { "type": "string", "format": "uri" },
            "signal_confidence": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 1.0
            }
          }
        }
      }
    },
    "tech_stack": {
      "type": "array",
      "items": { "type": "string" }
    },
    "bench_to_brief_match": {
      "type": "object",
      "properties": {
        "required_stacks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "bench_available": {
          "type": "boolean"
        },
        "gaps": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "data_sources_checked": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source", "status"],
        "properties": {
          "source": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["success", "partial", "no_data", "error", "rate_limited"]
          },
          "error_message": { "type": "string" },
          "fetched_at": { "type": "string", "format": "date-time" }
        }
      }
    },
    "honesty_flags": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "weak_hiring_velocity_signal",
          "weak_ai_maturity_signal",
          "conflicting_segment_signals",
          "layoff_overrides_funding",
          "bench_gap_detected",
          "tech_stack_inferred_not_confirmed"
        ]
      }
    }
  }
}